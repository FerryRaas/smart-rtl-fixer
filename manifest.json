{
  "manifest_version": 2,
  "name": "Smart RTL Fixer",
  "version": "1.0.0",
  "description": "Privacy-first RTL/LTR fixer for mixed Arabic and English text on modern web apps.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "browser_action": {
    "default_title": "Smart RTL Fixer",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "applications": {
    "gecko": {
      "id": "smart-rtl-fixer@example.com",
      "strict_min_version": "109.0"
    }
  }
}